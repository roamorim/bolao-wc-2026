# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# Banco de dados
DB_NAME=bolao
DB_USERNAME=bolao
DB_PASSWORD=TROQUE_PARA_SENHA_SEGURA

# Porta do app (opcional, padrão: 8080)
APP_PORT=8080

# GitHub username (para docker-compose.prod.yml — imagem do GHCR)
GHCR_USER=seu-usuario-github

# Email (Gmail SMTP) — requer App Password com 2FA ativo
MAIL_ENABLED=false
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=app-password-16-chars

# Customização da página de login
BOLAO_SUBTITLE=Câmara dos Lordes
BOLAO_PAYMENT_AMOUNT=R$ 150
BOLAO_PAYMENT_KEY=sua-chave-pix
BOLAO_CONTACT_URL=https://wa.me/5511999999999
BOLAO_CONTACT_LABEL=Falar com o Rodrigo
