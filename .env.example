# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# Banco de dados
DB_NAME=bolao
DB_USERNAME=bolao
DB_PASSWORD=TROQUE_PARA_SENHA_SEGURA

# Porta do app (opcional, padrão: 8080)
APP_PORT=8080

# Chave secreta para assinar o cookie "lembrar-me" (gere com: openssl rand -hex 32)
# IMPORTANTE: precisa ser fixa em produção — se mudar a cada deploy, todos os cookies
# "lembrar-me" existentes são invalidados.
REMEMBER_ME_KEY=gere-uma-chave-aleatoria-fixa

# GitHub username (para docker-compose.prod.yml — imagem do GHCR)
GHCR_USER=seu-usuario-github

# Email (Gmail SMTP) — requer App Password com 2FA ativo
MAIL_ENABLED=false
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=app-password-16-chars

# Customização da página de login
BOLAO_SUBTITLE=Câmara dos Lordes
BOLAO_PAYMENT_AMOUNT=R$ 150
BOLAO_PAYMENT_KEY=sua-chave-pix
BOLAO_CONTACT_URL=https://wa.me/5511999999999
BOLAO_CONTACT_LABEL=Falar com o Rodrigo

# Premiação — valor numérico por participante e símbolo da moeda (para cálculo)
# Exemplo BRL: BOLAO_PAYMENT_AMOUNT_VALUE=150  BOLAO_CURRENCY_SYMBOL=R$
# Exemplo CLP: BOLAO_PAYMENT_AMOUNT_VALUE=20000 BOLAO_CURRENCY_SYMBOL=$
BOLAO_PAYMENT_AMOUNT_VALUE=150
BOLAO_CURRENCY_SYMBOL=R$
# Custo de hospedagem na moeda local (~10 USD — a ser confirmado)
# BRL: BOLAO_HOSTING_COST=50  |  CLP: BOLAO_HOSTING_COST=10000
BOLAO_HOSTING_COST=50

# Easter egg: troca o nome do usuário logado por um apelido só na própria
# linha dele no ranking (as outras entradas continuam com o nome real).
# Deixe desligado (false) nas instâncias onde isso não faz sentido.
BOLAO_RANKING_SELF_ALIAS_ENABLED=false
BOLAO_RANKING_SELF_ALIAS_NAME=Rato
